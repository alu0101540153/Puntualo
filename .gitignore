# ---- Global / root .gitignore for Proyecto-E20 ----

# Node (root-level)
node_modules/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Build / output
dist/
build/
public/build/

# Environment files (don't commit secrets)
.env
.env.*

# TypeScript
*.tsbuildinfo

# Test coverage and reports
coverage/
coverage-final.json
nyc_output/
playwright-report/

# Vite / cache
.vite/
.cache/

# Editor / OS
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Ignore node_modules for subprojects explicitly (keeps workspace tidy)
/client/node_modules/
/server/node_modules/

# Optional: lockfiles should usually be committed. Do not ignore package-lock.json / yarn.lock / pnpm-lock.yaml unless intentional.

# End of root .gitignore

